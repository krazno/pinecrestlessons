{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "redirects": [
    { "source": "/pinecrest", "destination": "/", "permanent": false },
    { "source": "/pinecrest/", "destination": "/", "permanent": false },
    { "source": "/pinecrest/class", "destination": "/", "permanent": false },
    { "source": "/pinecrest/class/", "destination": "/", "permanent": false },
    { "source": "/pinecrest-student", "destination": "/", "permanent": false },
    { "source": "/pinecrest-student/", "destination": "/", "permanent": false },
    { "source": "/pinecrest-student/:path*", "destination": "/", "permanent": false },
    { "source": "/pinecrest-teacher", "destination": "/", "permanent": false },
    { "source": "/pinecrest-teacher/", "destination": "/", "permanent": false },
    { "source": "/pinecrest-teacher/:path*", "destination": "/", "permanent": false },
    { "source": "/pinecrest-teacher/activity-submissions", "destination": "/", "permanent": false },
    { "source": "/pinecrest-teacher/activity-submissions/", "destination": "/", "permanent": false },
    { "source": "/student", "destination": "/", "permanent": false },
    { "source": "/student/", "destination": "/", "permanent": false },
    { "source": "/student/:path*", "destination": "/", "permanent": false },
    { "source": "/class", "destination": "/", "permanent": false },
    { "source": "/class/", "destination": "/", "permanent": false },
    { "source": "/class/:path*", "destination": "/", "permanent": false }
  ]
}
